# Schematix configuration — copy to .env and fill in.

# ── API key (required) ────────────────────────────────────────────────
# Either name works for the primary key.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Optional fallback keys — the server rotates to the next one automatically
# when the previous hits quota / 429 / 503.  Any of these forms works:
#
#   GEMINI_API_KEYS=key1,key2,key3      (comma-separated, single line)
#   GEMINI_API_KEY_2=...                (numbered, up to _5)
#   GEMINI_API_KEY_3=...
#   GEMINI_API_KEY_FALLBACK=...         (alias)
#
# Fallbacks are silent — the UI never sees the first key's failure.
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# ── Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
NO_BROWSER=1

# ── CORS lockdown (production) ───────────────────────────────────────
# Comma-separated origins. Use '*' only for development.
# Example: ALLOWED_ORIGINS=https://schematix.example.com,https://app.example.com
ALLOWED_ORIGINS=*

# ── Cost analysis default mode ───────────────────────────────────────
# true  = real prices via Gemini Google-Search grounding (~20–40s per run, accurate)
# false = fast estimation from Gemini training data (~5–8s per run, indicative)
# Frontend can still override per-request by sending {"grounded": true|false}.
COST_GROUNDED=true
